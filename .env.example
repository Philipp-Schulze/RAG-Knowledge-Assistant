# data base
DATABASE_URL=postgresql://postgres:password123@rag_postgres:5432/rag_db

# embedding
EMBEDDING_MODEL=nomic-embed-text

# local llm
# Native Ollama runs on the host; containers reach it via host.docker.internal.
# Run a second `ollama serve` bound to 0.0.0.0:11435 per session (see CLAUDE.md),
# or use docker-compose.demo.yml to containerize Ollama instead (OLLAMA_URL=http://ollama:11434/api/generate).
OLLAMA_URL=http://host.docker.internal:11435/api/generate

MODEL_SUMMARIZER_FAST=qwen2.5:1.5b
MODEL_SUMMARIZER_COMPLEX=qwen2.5:7b
MODEL_GENERATOR_FAST=qwen2.5:3b
MODEL_GENERATOR_COMPLEX=qwen2.5:7b
MODEL_JUDGE=llama-guard3:1b

# api llm (provider="api"): OpenAI-compatible chat-completions endpoint
# Supported API_PROVIDER values: "gemini" (adds Gemini-specific thinking_config), "groq", or any other
# OpenAI-compatible provider.
API_PROVIDER=gemini
API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
API_KEY=<your Gemini API key>
API_MODEL=gemini-2.5-flash

# Groq alternative (free tier, OpenAI-compatible, very fast open models):
# API_PROVIDER=groq
# API_BASE_URL=https://api.groq.com/openai/v1/chat/completions
# API_KEY=<your Groq API key>
# API_MODEL=llama-3.3-70b-versatile

# web crawling (only used after the user explicitly confirms a web search in the UI)
TAVILY_URL=https://api.tavily.com/search
TAVILY_API_KEY=<your Tavily API key>

# Brave Search API alternative (free tier: 2,000 queries/month, https://brave.com/search/api/):
# would require adapting app/search.py to Brave's request/response format (GET with
# "X-Subscription-Token" header instead of Tavily's POST body, and a different result schema).
# BRAVE_SEARCH_URL=https://api.search.brave.com/res/v1/web/search
# BRAVE_SEARCH_API_KEY=<your Brave Search API key>
